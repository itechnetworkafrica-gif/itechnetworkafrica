# ─── Gotecx Frontend — Environment Variables ───────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# On Vercel, set these in the Environment Variables dashboard.
#
# Both variables are OPTIONAL — the app works as a static site without them.
# They are only needed when running the dev server locally inside the
# Replit monorepo where PORT and BASE_PATH are injected by the workflow runner.
#
# PORT      — local dev server port (default: 5173)
# BASE_PATH — URL base path if hosted at a sub-path (default: /)
#
# PORT=5173
# BASE_PATH=/
