# ─── Gotecx API Server — Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in your values.
# On Railway / Render / Fly.io, set these in your service's environment settings.
#

# Required — TCP port the server listens on
PORT=5000

# Required — PostgreSQL connection string
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=postgres://user:password@localhost:5432/gotecx

# Optional — set to "production" in deployed environments
NODE_ENV=development
